{
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**", "obj/**"]
      }
    ],
        "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "fileMetadata": {
      "api/**/toc.yml": {
        "pdf": true
      }
    },
    "markdownEngineProperties": {
      "markdigExtensions": [
        "diagrams"
      ]
    },
    "dest": "_site",
    "template": ["default", "modern", "mytemplate"],
    "globalMetadata": {
      "_appLogoPath": "images/logo.svg",
      "_appTitle": "ictinternational.com",
      "_appName": "ictinternational.com",
      "_enableSearch": true,
      "_baseUrl": "/docfx-site-e",
      "_enableContribution": true,
      "_gitContribute": {
        "repo": "https://github.com/Bikal-ICT-International/docfx-site-e",
        "branch": "main",
        "path": ""
      },
      "pdf": true,
      "pdfFileName": "ICT Product Support Handbook.pdf",
      "_appFooter": "<div style='width: 100%; text-align: center;'><span>Copyright © 2026 ICT International</span></div>"
    }
  }
}

  
